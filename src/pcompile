#!/usr/bin/env bash
#
# Wrapper for pcompile that supports -D flags
#

PICDIR=/nix/store/arwhjx9g43m3jbh2lgzblh67dkmflrg0-pic32-toolchain-2017.09.15/opt/pic32mx
USAGE="usage: $0 [-Dmacro[=value] ...] c_or_cpp_or_asm_file [c_or_cpp_or_asm_file ...]"

# Separate -D flags from source files
EXTRA_CFLAGS=""
SRCS=""

for arg in "$@"; do
    case "$arg" in
        -D*)
            EXTRA_CFLAGS="$EXTRA_CFLAGS $arg"
            ;;
        *)
            SRCS="$SRCS $arg"
            ;;
    esac
done

# Trim leading space
SRCS=$(echo "$SRCS" | sed 's/^ *//')

if [ -z "$SRCS" ]; then
    echo $USAGE
    exit 0
fi

# Determine target name from first source
f=$(echo "$SRCS" | awk '{print $1}')
case $f in
    (*.c)
        g=${f/%.c/}
        ;;
    (*.cpp)
        g=${f/%.cpp/}
        ;;
    (*.s)
        g=${f/%.s/}
        ;;
    (*)
        echo -e "\nunknown file type ($f)\n\n"
        echo $USAGE
        exit 1
        ;;
esac

rm -f *.o *.elf *.hex *.map *.hex.s

set -e

# Compile
obj=""
for f in $SRCS; do
    echo "*** compiling $f ..."
    case $f in
        (*.c)
            $PICDIR/bin/pic32-gcc -Wall -O2 -mprocessor=32MX795F512H -I$PICDIR/include $EXTRA_CFLAGS -c $f -o ${f/%.c/.o}
            obj="$obj ${f/%.c/.o}"
            ;;
        (*.cpp)
            $PICDIR/bin/pic32-g++ -Wall -O2 -mprocessor=32MX795F512H -I$PICDIR/include $EXTRA_CFLAGS -c $f -o ${f/%.cpp/.o}
            obj="$obj ${f/%.cpp/.o}"
            ;;
        (*.s)
            $PICDIR/bin/pic32-gcc -Wall -O2 -mprocessor=32MX795F512H -I$PICDIR/include $EXTRA_CFLAGS -c $f -o ${f/%.s/.o}
            obj="$obj ${f/%.s/.o}"
            ;;
        (*)
            echo -e "\nunknown file type ($f)\n"
            exit 1
            ;;
    esac
done

# Link
echo "*** linking $g ..."
$PICDIR/bin/pic32-ld $obj -o $g.elf -L$PICDIR/lib -L$PICDIR/lib/gcc/pic32mx/3.4.4 -ldetpic32 -lgcc -lm -lc -lsupc++ -lxcpp -Map $g.map

# Convert to hex
echo "*** converting to .hex ..."
$PICDIR/bin/pic32-bin2hex $g.elf

echo "*** done ($g.hex created with success)"
exit 0
